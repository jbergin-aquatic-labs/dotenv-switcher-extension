{
  "name": "env-switcher",
  "displayName": "Env Switcher",
  "description": "Quickly switch between .env files by symlinking from a .envs folder",
  "version": "0.1.0",
  "publisher": "aquatic-labs",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.envs"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "env-switcher",
          "title": "Env Switcher",
          "icon": "assets/activitybar-icon.svg"
        }
      ]
    },
    "views": {
      "env-switcher": [
        {
          "id": "envSwitcher.envFiles",
          "name": "Env Files"
        },
        {
          "id": "envSwitcher.projectFolders",
          "name": "Project Folders"
        }
      ]
    },
    "commands": [
      {
        "command": "envSwitcher.switchEnv",
        "title": "Env Switcher: Select Environment"
      },
      {
        "command": "envSwitcher.refreshEnvList",
        "title": "Refresh Environments",
        "icon": "$(refresh)"
      },
      {
        "command": "envSwitcher.assignEnv",
        "title": "Assign .env File"
      },
      {
        "command": "envSwitcher.unassignEnv",
        "title": "Remove .env Assignment"
      },
      {
        "command": "envSwitcher.openEnvFile",
        "title": "Open in Editor"
      },
      {
        "command": "envSwitcher.backupNow",
        "title": "Env Switcher: Backup .envs to Local Storage"
      },
      {
        "command": "envSwitcher.restoreBackup",
        "title": "Env Switcher: Restore .envs from Local Backup"
      }
    ],
    "configuration": {
      "title": "Env Switcher",
      "properties": {
        "envSwitcher.envFolder": {
          "type": "string",
          "default": ".envs",
          "description": "Folder name containing your .env files (relative to workspace root)"
        },
        "envSwitcher.targetFile": {
          "type": "string",
          "default": ".env",
          "description": "Target .env filename to symlink to (relative to each target directory)"
        },
        "envSwitcher.autoBackup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically back up the .envs folder to VS Code's local storage whenever it changes. Backups survive repo deletion and can be restored into a fresh clone."
        },
        "envSwitcher.excludedFolders": {
          "type": "array",
          "default": ["node_modules", ".git", ".vscode", "dist", "build", ".next", "coverage", "__pycache__", ".cache"],
          "description": "Folders to hide from the Project Folders tree view.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "envSwitcher.refreshEnvList",
          "when": "view == envSwitcher.envFiles || view == envSwitcher.projectFolders",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "envSwitcher.assignEnv",
          "when": "view == envSwitcher.projectFolders && viewItem == projectFolder",
          "group": "envSwitcher@1"
        },
        {
          "command": "envSwitcher.assignEnv",
          "when": "view == envSwitcher.projectFolders && viewItem == projectFolderAssigned",
          "group": "envSwitcher@1"
        },
        {
          "command": "envSwitcher.unassignEnv",
          "when": "view == envSwitcher.projectFolders && viewItem == projectFolderAssigned",
          "group": "envSwitcher@2"
        },
        {
          "command": "envSwitcher.openEnvFile",
          "when": "view == envSwitcher.envFiles && viewItem == envFile",
          "group": "envSwitcher@1"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "envSwitcher.envFiles",
        "contents": "No .envs folder found.\nCreate a `.envs` folder in your workspace root and add your environment files (e.g. `.env.dev`, `.env.production`).\n[Select Environment via Command Palette](command:envSwitcher.switchEnv)"
      }
    ]
  },
  "scripts": {
    "package": "node scripts/generate-icon.js && npx @vscode/vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0",
    "sharp": "^0.34.5"
  }
}
